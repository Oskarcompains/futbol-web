<%- include('partials/header', { titulo: producto.nombre, descripcion: producto.descripcion }) %>

<div class="page-header">
  <div class="page-header-inner">
    <div class="page-breadcrumb"><a href="/">Inicio</a> / <a href="/tienda">Tienda</a> / <%= producto.categoria %></div>
    <h1 class="page-h1" style="font-size:clamp(2rem,4vw,3rem)"><%= producto.nombre %></h1>
  </div>
</div>

<div class="seccion">
  <% if (success) { %>
  <div class="alerta alerta-exito">✅ <%= success %></div>
  <% } %>
  <% if (error) { %>
  <div class="alerta alerta-error">⚠️ <%= error %></div>
  <% } %>

  <div class="producto-detalle-grid">
    <div class="producto-img-grande">
      <%= producto.categoria === 'Camisetas' ? '👕' : producto.categoria === 'Ropa' ? '🧥' : producto.categoria === 'Accesorios' ? '🧢' : '⚽' %>
    </div>
    <div>
      <div style="font-family:var(--font-condensed);font-size:0.8rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--rojo);margin-bottom:0.5rem"><%= producto.categoria %></div>
      <h2 style="font-family:var(--font-titulo);font-size:2.5rem;letter-spacing:0.02em"><%= producto.nombre %></h2>
      <div class="producto-precio-grande"><%= producto.precio.toFixed(2) %>€</div>
      <p style="color:var(--gris-claro);line-height:1.7;margin-bottom:2rem"><%= producto.descripcion || 'Producto oficial del club.' %></p>

      <% if (producto.stock === 0) { %>
        <div class="alerta alerta-error" style="margin-bottom:1.5rem">Este producto está actualmente agotado.</div>
      <% } else { %>
        <% if (producto.stock < 10) { %>
          <div style="margin-bottom:1rem;font-size:0.85rem;color:#f59e0b;font-family:var(--font-condensed);font-weight:600">
            ⚠️ Pocas unidades — solo quedan <%= producto.stock %>
          </div>
        <% } %>

        <form action="/tienda/pedido" method="POST" id="form-pedido">
          <input type="hidden" name="producto_id" value="<%= producto.id %>">
          <div class="form-grid" style="grid-template-columns:1fr 1fr">
            <div class="form-group">
              <label class="form-label">Tu nombre *</label>
              <input type="text" name="nombre" class="form-input" required placeholder="Nombre completo">
            </div>
            <div class="form-group">
              <label class="form-label">Email *</label>
              <input type="email" name="email" class="form-input" required placeholder="tu@email.com">
            </div>

            <% const conTalla = ['Camisetas', 'Ropa'].includes(producto.categoria); %>
            <% if (conTalla) { %>
            <div class="form-group">
              <label class="form-label">Talla</label>
              <select name="talla" class="form-select">
                <option value="XS">XS</option>
                <option value="S">S</option>
                <option value="M" selected>M</option>
                <option value="L">L</option>
                <option value="XL">XL</option>
                <option value="XXL">XXL</option>
              </select>
            </div>
            <% } else { %>
            <input type="hidden" name="talla" value="Única">
            <% } %>

            <div class="form-group">
              <label class="form-label">Cantidad</label>
              <input type="number" name="cantidad" id="cantidad-input" class="form-input" value="1" min="1" max="<%= Math.min(10, producto.stock) %>">
            </div>
          </div>
          <button type="submit" class="btn btn-primario form-submit" id="btn-pedido" style="margin-top:1.5rem">
            Realizar Pedido — <%= producto.precio.toFixed(2) %>€
          </button>
        </form>

        <div style="margin-top:1.5rem;font-size:0.82rem;color:#555;font-family:var(--font-condensed)">
          📦 Te contactaremos por email para confirmar el pedido y la forma de pago.
        </div>

        <script>
          (function() {
            const precioBase = <%= producto.precio %>;
            const cantidadInput = document.getElementById('cantidad-input');
            const btn = document.getElementById('btn-pedido');

            function actualizarTotal() {
              const cantidad = parseInt(cantidadInput.value) || 1;
              const total = (precioBase * cantidad).toFixed(2);
              btn.textContent = 'Realizar Pedido — ' + total + '€';
            }

            cantidadInput.addEventListener('input', actualizarTotal);
            actualizarTotal();
          })();
        </script>
      <% } %>
    </div>
  </div>

  <div style="margin-top:3rem">
    <a href="/tienda" class="btn btn-secundario">← Volver a la Tienda</a>
  </div>
</div>

<%- include('partials/footer') %>
