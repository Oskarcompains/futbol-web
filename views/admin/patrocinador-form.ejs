<%- include('layout-top', { titulo: patrocinador ? 'Editar patrocinador' : 'Nuevo patrocinador', activePage: 'patrocinadores', admin }) %>

<div class="page-hdr">
  <h1><%= patrocinador ? 'Editar patrocinador' : 'Nuevo patrocinador' %></h1>
  <a href="/admin/patrocinadores" class="btn btn-outline">← Volver</a>
</div>

<div class="form-card">
  <form action="<%= patrocinador ? '/admin/patrocinadores/editar/'+patrocinador.id : '/admin/patrocinadores/nuevo' %>" method="POST">
    <div class="form-grid">
      <div class="form-group full">
        <label class="form-label">Nombre de la empresa *</label>
        <input type="text" name="nombre" class="form-input" required value="<%= patrocinador ? patrocinador.nombre : '' %>" placeholder="Ej: Deportes Navarra">
      </div>
      <div class="form-group">
        <label class="form-label">Nivel de patrocinio</label>
        <select name="nivel" class="form-select">
          <option value="3" <%= patrocinador && patrocinador.nivel === 3 ? 'selected' : '' %>>⭐ Principal (Oro)</option>
          <option value="2" <%= patrocinador && patrocinador.nivel === 2 ? 'selected' : '' %>>Colaborador (Plata)</option>
          <option value="1" <%= !patrocinador || patrocinador.nivel === 1 ? 'selected' : '' %>>Amigo del Club (Bronce)</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Sitio web</label>
        <input type="url" name="web" class="form-input" value="<%= patrocinador ? patrocinador.web : '' %>" placeholder="https://empresa.com">
      </div>
      <div class="form-group full">
        <label class="form-label">Descripción breve</label>
        <textarea name="descripcion" class="form-textarea" style="min-height:90px" placeholder="Breve descripción de la empresa o su relación con el club..."><%= patrocinador ? patrocinador.descripcion : '' %></textarea>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-rojo"><%= patrocinador ? '💾 Guardar cambios' : '+ Añadir patrocinador' %></button>
      <a href="/admin/patrocinadores" class="btn btn-outline">Cancelar</a>
    </div>
  </form>
</div>

<%- include('layout-bottom') %>
