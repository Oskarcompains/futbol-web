<%- include('layout-top', { titulo: noticia ? 'Editar noticia' : 'Nueva noticia', activePage: 'noticias', admin }) %>

<div class="page-hdr">
  <h1><%= noticia ? 'Editar noticia' : 'Nueva noticia' %></h1>
  <a href="/admin/noticias" class="btn btn-outline">← Volver</a>
</div>

<div class="form-card">
  <form action="<%= noticia ? '/admin/noticias/editar/'+noticia.id : '/admin/noticias/nueva' %>" method="POST">
    <div class="form-grid">
      <div class="form-group full">
        <label class="form-label">Título *</label>
        <input type="text" name="titulo" class="form-input" required value="<%= noticia ? noticia.titulo : '' %>" placeholder="Título de la noticia">
      </div>
      <div class="form-group full">
        <label class="form-label">Resumen *</label>
        <input type="text" name="resumen" class="form-input" required value="<%= noticia ? noticia.resumen : '' %>" placeholder="Breve descripción (aparece en las tarjetas)">
      </div>
      <div class="form-group">
        <label class="form-label">Categoría</label>
        <select name="categoria" class="form-select">
          <% ['General','Partidos','Club','Fichajes','Pretemporada'].forEach(cat => { %>
          <option value="<%= cat %>" <%= noticia && noticia.categoria === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Fecha</label>
        <input type="date" name="fecha" class="form-input" value="<%= noticia ? noticia.fecha : new Date().toISOString().split('T')[0] %>">
      </div>
      <div class="form-group full">
        <label class="form-label">Contenido completo *</label>
        <textarea name="contenido" class="form-textarea" required style="min-height:220px" placeholder="Texto completo de la noticia..."><%= noticia ? noticia.contenido : '' %></textarea>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-rojo"><%= noticia ? '💾 Guardar cambios' : '+ Publicar noticia' %></button>
      <a href="/admin/noticias" class="btn btn-outline">Cancelar</a>
    </div>
  </form>
</div>

<%- include('layout-bottom') %>
