<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acceso Admin — ClubFC</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600&family=Barlow+Condensed:wght@600;700&display=swap">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Barlow', sans-serif; background: #0A0A0A; color: #F0EEE9; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-box { width: 100%; max-width: 400px; padding: 2rem; }
    .login-logo { font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
    .login-logo span { color: #E8132B; }
    .login-sub { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; color: #666; margin-bottom: 2.5rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.1rem; }
    label { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #888; }
    input { background: #1A1A1A; border: 1px solid rgba(255,255,255,0.08); color: #F0EEE9; padding: 0.75rem 1rem; font-family: 'Barlow', sans-serif; font-size: 1rem; outline: none; width: 100%; transition: border-color 0.2s; }
    input:focus { border-color: #E8132B; }
    .btn-login { width: 100%; background: #E8132B; color: white; border: none; padding: 0.85rem; font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; cursor: pointer; margin-top: 0.5rem; transition: background 0.2s; }
    .btn-login:hover { background: #B50F22; }
    .error { background: rgba(232,19,43,0.1); border: 1px solid rgba(232,19,43,0.25); color: #ff6b7a; padding: 0.75rem 1rem; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .hint { font-size: 0.78rem; color: #444; margin-top: 1.25rem; text-align: center; }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="login-logo">⚽ Club<span>FC</span></div>
    <div class="login-sub">Panel de Administración</div>

    <% if (error) { %>
    <div class="error">⚠️ <%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label for="usuario">Usuario</label>
        <input type="text" id="usuario" name="usuario" required autocomplete="username" placeholder="admin">
      </div>
      <div class="form-group">
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" required autocomplete="current-password">
      </div>
      <button type="submit" class="btn-login">Entrar →</button>
    </form>
    <div class="hint">Acceso restringido al personal del club</div>
  </div>
</body>
</html>
