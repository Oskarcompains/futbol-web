<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof titulo !== 'undefined' ? titulo + ' — Admin' : 'Panel Admin' %> | ClubFC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;600;700;900&display=swap">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --rojo: #E8132B; --rojo-o: #B50F22;
      --negro: #0A0A0A; --negro-s: #111;
      --gris-1: #1A1A1A; --gris-2: #222; --gris-3: #2E2E2E; --gris-4: #3E3E3E;
      --texto: #F0EEE9; --texto-s: #999; --acento: #FFD700;
      --verde: #27AE60; --amarillo: #F39C12; --azul: #2980B9;
      --font-t: 'Bebas Neue', sans-serif;
      --font-c: 'Barlow Condensed', sans-serif;
      --font-b: 'Barlow', sans-serif;
      --sidebar: 240px;
    }
    html, body { height: 100%; }
    body { font-family: var(--font-b); background: var(--negro); color: var(--texto); display: flex; }

    /* ── SIDEBAR ── */
    .sidebar {
      width: var(--sidebar); min-height: 100vh;
      background: var(--negro-s);
      border-right: 1px solid rgba(255,255,255,0.05);
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0;
      z-index: 50;
    }
    .sidebar-logo {
      padding: 1.5rem 1.25rem;
      font-family: var(--font-t); font-size: 1.5rem; letter-spacing: 0.05em;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex; align-items: center; gap: 0.5rem;
    }
    .sidebar-logo span { color: var(--rojo); }
    .sidebar-badge {
      font-family: var(--font-c); font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--texto-s); padding: 0.15rem 0.5rem;
      background: rgba(255,255,255,0.06); border-radius: 2px; margin-left: auto;
    }
    .sidebar-nav { flex: 1; padding: 1rem 0; overflow-y: auto; }
    .nav-section {
      font-family: var(--font-c); font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.25em; text-transform: uppercase; color: #444;
      padding: 1rem 1.25rem 0.4rem;
    }
    .nav-item {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.6rem 1.25rem;
      font-family: var(--font-c); font-size: 0.95rem; font-weight: 600;
      letter-spacing: 0.05em; color: var(--texto-s);
      text-decoration: none;
      transition: all 0.2s; position: relative;
    }
    .nav-item:hover { color: var(--texto); background: rgba(255,255,255,0.04); }
    .nav-item.active { color: var(--texto); background: rgba(232,19,43,0.1); }
    .nav-item.active::before {
      content: ''; position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px; background: var(--rojo);
    }
    .nav-item .icon { font-size: 1rem; width: 20px; text-align: center; }
    .badge-count {
      margin-left: auto; background: var(--rojo); color: white;
      font-size: 0.7rem; font-weight: 700; padding: 0.1rem 0.45rem;
      border-radius: 10px; font-family: var(--font-b);
    }
    .sidebar-footer {
      padding: 1rem 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      font-size: 0.82rem; color: var(--texto-s);
    }
    .sidebar-footer strong { color: var(--texto); display: block; margin-bottom: 0.5rem; }
    .sidebar-footer a { color: var(--rojo); text-decoration: none; font-size: 0.82rem; }

    /* ── MAIN ── */
    .main { margin-left: var(--sidebar); flex: 1; min-height: 100vh; display: flex; flex-direction: column; }
    .topbar {
      background: var(--negro-s); border-bottom: 1px solid rgba(255,255,255,0.05);
      padding: 0 2rem; height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 40;
    }
    .topbar-titulo { font-family: var(--font-t); font-size: 1.4rem; letter-spacing: 0.05em; }
    .topbar-right { display: flex; align-items: center; gap: 1rem; }
    .topbar-right a {
      font-family: var(--font-c); font-size: 0.8rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase; color: var(--texto-s);
      text-decoration: none; transition: color 0.2s;
    }
    .topbar-right a:hover { color: var(--rojo); }
    .content { padding: 2rem; flex: 1; }

    /* ── CARDS ── */
    .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1px; background: var(--gris-3); margin-bottom: 2rem; }
    .stat-card { background: var(--gris-1); padding: 1.5rem; }
    .stat-card-num { font-family: var(--font-t); font-size: 2.8rem; color: var(--rojo); line-height: 1; }
    .stat-card-label { font-family: var(--font-c); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--texto-s); margin-top: 0.4rem; }
    .stat-card-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }

    /* ── TABLE ── */
    .tabla { width: 100%; border-collapse: collapse; }
    .tabla th { font-family: var(--font-c); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--texto-s); padding: 0.75rem 1rem; text-align: left; background: var(--gris-1); border-bottom: 1px solid var(--gris-3); }
    .tabla td { padding: 0.8rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.95rem; vertical-align: middle; }
    .tabla tr:hover td { background: rgba(255,255,255,0.02); }
    .tabla-wrap { background: var(--negro-s); border: 1px solid rgba(255,255,255,0.06); overflow-x: auto; }

    /* ── BUTTONS ── */
    .btn { font-family: var(--font-c); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.5rem 1.1rem; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none; transition: all 0.2s; white-space: nowrap; }
    .btn-rojo { background: var(--rojo); color: white; }
    .btn-rojo:hover { background: var(--rojo-o); }
    .btn-gris { background: var(--gris-3); color: var(--texto); }
    .btn-gris:hover { background: var(--gris-4); }
    .btn-outline { background: transparent; color: var(--texto-s); border: 1px solid var(--gris-3); }
    .btn-outline:hover { border-color: var(--rojo); color: var(--rojo); }
    .btn-peligro { background: transparent; color: #ff6b7a; border: 1px solid rgba(255,107,122,0.3); }
    .btn-peligro:hover { background: rgba(255,107,122,0.1); }
    .btn-sm { padding: 0.3rem 0.75rem; font-size: 0.75rem; }
    .btn-xs { padding: 0.2rem 0.55rem; font-size: 0.7rem; }

    /* ── FORMS ── */
    .form-card { background: var(--gris-1); border: 1px solid rgba(255,255,255,0.06); padding: 2rem; max-width: 720px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-group.full { grid-column: 1/-1; }
    .form-label { font-family: var(--font-c); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--texto-s); }
    .form-input, .form-textarea, .form-select { background: var(--gris-2); border: 1px solid rgba(255,255,255,0.08); color: var(--texto); padding: 0.7rem 0.9rem; font-family: var(--font-b); font-size: 0.95rem; outline: none; transition: border-color 0.2s; width: 100%; }
    .form-input:focus, .form-textarea:focus, .form-select:focus { border-color: var(--rojo); }
    .form-textarea { resize: vertical; min-height: 120px; }
    .form-select option { background: var(--gris-2); }

    /* ── PAGE HEADER ── */
    .page-hdr { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .page-hdr h1 { font-family: var(--font-t); font-size: 2rem; letter-spacing: 0.03em; }

    /* ── ALERTS ── */
    .alerta { padding: 0.8rem 1.2rem; font-family: var(--font-c); font-weight: 600; font-size: 0.95rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.6rem; }
    .alerta-ok { background: rgba(39,174,96,0.12); border: 1px solid rgba(39,174,96,0.25); color: #6fcf97; }
    .alerta-err { background: rgba(232,19,43,0.12); border: 1px solid rgba(232,19,43,0.25); color: #ff6b7a; }

    /* ── BADGES ── */
    .badge { font-family: var(--font-c); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.55rem; border-radius: 2px; }
    .badge-rojo { background: rgba(232,19,43,0.15); color: var(--rojo); }
    .badge-verde { background: rgba(39,174,96,0.15); color: #6fcf97; }
    .badge-amarillo { background: rgba(243,156,18,0.15); color: #f5a623; }
    .badge-gris { background: rgba(255,255,255,0.08); color: var(--texto-s); }

    /* ── ACCIONES FORM ── */
    .form-actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); transition: transform 0.3s; }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    ⚽ Club<span>FC</span>
    <span class="sidebar-badge">Admin</span>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">Principal</div>
    <a href="/admin" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
      <span class="icon">📊</span> Dashboard
    </a>

    <div class="nav-section">Contenido</div>
    <a href="/admin/noticias" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'noticias' ? 'active' : '' %>">
      <span class="icon">📰</span> Noticias
    </a>
    <a href="/admin/jugadores" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'jugadores' ? 'active' : '' %>">
      <span class="icon">⚽</span> Jugadores
    </a>
    <a href="/admin/patrocinadores" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'patrocinadores' ? 'active' : '' %>">
      <span class="icon">🤝</span> Patrocinadores
    </a>

    <div class="nav-section">Tienda</div>
    <a href="/admin/productos" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'productos' ? 'active' : '' %>">
      <span class="icon">🛍️</span> Productos
    </a>
    <a href="/admin/pedidos" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'pedidos' ? 'active' : '' %>">
      <span class="icon">📦</span> Pedidos
    </a>

    <div class="nav-section">Comunicación</div>
    <a href="/admin/mensajes" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'mensajes' ? 'active' : '' %>">
      <span class="icon">✉️</span> Mensajes
    </a>

    <div class="nav-section">Cuenta</div>
    <a href="/admin/ajustes" class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'ajustes' ? 'active' : '' %>">
      <span class="icon">⚙️</span> Ajustes
    </a>
  </nav>
  <div class="sidebar-footer">
    <strong>👤 <%= typeof admin !== 'undefined' ? admin : 'Admin' %></strong>
    <a href="/" target="_blank">Ver web pública ↗</a> &nbsp;·&nbsp;
    <a href="/admin/logout">Cerrar sesión</a>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-titulo"><%= typeof titulo !== 'undefined' ? titulo : 'Panel Admin' %></div>
    <div class="topbar-right">
      <a href="/" target="_blank">🌐 Ver web</a>
      <a href="/admin/logout">Salir</a>
    </div>
  </div>
  <div class="content">
