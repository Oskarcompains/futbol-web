<%- include('layout-top', { titulo: 'Pedidos', activePage: 'pedidos', admin }) %>

<div class="page-hdr">
  <h1>Pedidos de la tienda</h1>
  <span style="font-family:var(--font-c);font-size:0.85rem;color:var(--texto-s)"><%= pedidos.length %> pedido<%= pedidos.length !== 1 ? 's' : '' %></span>
</div>

<div class="tabla-wrap">
  <% if (pedidos.length > 0) { %>
  <table class="tabla">
    <thead>
      <tr><th>ID</th><th>Cliente</th><th>Producto</th><th>Talla</th><th>Cant.</th><th>Total</th><th>Estado</th><th>Fecha</th><th>Acción</th></tr>
    </thead>
    <tbody>
      <% pedidos.forEach(p => { %>
      <tr>
        <td style="color:var(--texto-s);font-size:0.8rem">#<%= p.id %></td>
        <td>
          <strong><%= p.nombre %></strong><br>
          <a href="mailto:<%= p.email %>" style="font-size:0.78rem;color:var(--rojo)"><%= p.email %></a>
        </td>
        <td style="font-size:0.88rem"><%= p.producto_nombre || '—' %></td>
        <td style="font-size:0.85rem;color:var(--texto-s)"><%= p.talla %></td>
        <td style="text-align:center"><%= p.cantidad %></td>
        <td style="font-family:var(--font-c);font-weight:700;color:var(--rojo)"><%= p.total ? p.total.toFixed(2)+'€' : '—' %></td>
        <td>
          <span class="badge <%= p.estado === 'pendiente' ? 'badge-amarillo' : p.estado === 'completado' ? 'badge-verde' : p.estado === 'cancelado' ? 'badge-rojo' : 'badge-gris' %>">
            <%= p.estado %>
          </span>
        </td>
        <td style="font-size:0.78rem;color:var(--texto-s)"><%= new Date(p.fecha).toLocaleDateString('es-ES') %></td>
        <td>
          <form action="/admin/pedidos/estado/<%= p.id %>" method="POST" style="display:flex;gap:0.35rem;align-items:center">
            <select name="estado" class="form-select" style="padding:0.25rem 0.5rem;font-size:0.75rem;width:auto">
              <% ['pendiente','procesando','enviado','completado','cancelado'].forEach(s => { %>
              <option value="<%= s %>" <%= p.estado === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
            <button type="submit" class="btn btn-rojo btn-xs">✓</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
  <div style="padding:2rem;color:var(--texto-s)">📦 Todavía no hay pedidos. Aparecerán aquí cuando alguien compre en la tienda.</div>
  <% } %>
</div>

<%- include('layout-bottom') %>
