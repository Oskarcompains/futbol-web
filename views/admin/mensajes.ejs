<%- include('layout-top', { titulo: 'Mensajes', activePage: 'mensajes', admin }) %>

<div class="page-hdr">
  <h1>Mensajes de contacto</h1>
  <span style="font-family:var(--font-c);font-size:0.85rem;color:var(--texto-s)"><%= mensajes.length %> mensaje<%= mensajes.length !== 1 ? 's' : '' %> en total</span>
</div>

<% if (mensajes.length > 0) { %>
<div style="display:flex;flex-direction:column;gap:1px;background:var(--gris-3)">
  <% mensajes.forEach(m => { %>
  <div style="background:var(--gris-1);padding:1.5rem;display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:start">
    <div>
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem">
        <strong style="font-size:1rem"><%= m.nombre %></strong>
        <span style="font-size:0.82rem;color:var(--texto-s)"><%= m.email %></span>
        <% if (!m.leido) { %><span class="badge badge-rojo">Nuevo</span><% } %>
      </div>
      <div style="font-family:var(--font-c);font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--rojo);margin-bottom:0.5rem">
        <%= m.asunto || 'Sin asunto' %>
      </div>
      <p style="color:var(--texto-s);font-size:0.93rem;line-height:1.6"><%= m.mensaje %></p>
      <div style="font-size:0.78rem;color:#444;margin-top:0.75rem">
        <%= new Date(m.fecha).toLocaleString('es-ES', {day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
      </div>
    </div>
    <div style="display:flex;flex-direction:column;gap:0.5rem;align-items:flex-end">
      <a href="mailto:<%= m.email %>?subject=Re: <%= encodeURIComponent(m.asunto || '') %>" class="btn btn-gris btn-sm">✉️ Responder</a>
      <form action="/admin/mensajes/eliminar/<%= m.id %>" method="POST" data-confirm="¿Eliminar este mensaje de <%= m.nombre %>?">
        <button type="submit" class="btn btn-peligro btn-sm">🗑 Borrar</button>
      </form>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<div style="background:var(--gris-1);padding:3rem;text-align:center;color:var(--texto-s)">
  ✉️ No hay mensajes todavía. Aparecerán aquí cuando alguien use el formulario de contacto.
</div>
<% } %>

<%- include('layout-bottom') %>
